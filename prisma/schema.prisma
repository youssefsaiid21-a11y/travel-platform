generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id               String           @id @default(cuid())
  email            String           @unique
  name             String?
  passwordHash     String
  createdAt        DateTime         @default(now())
  bookings         Booking[]
  passengerProfile PassengerProfile?
  trackedSearches  TrackedSearch[]
}

model PassengerProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  givenName       String
  familyName      String
  bornOn          String
  gender          String
  title           String
  phone           String
  specialRequests String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id])
}

model ChatSession {
  id          String   @id
  sessionData String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([updatedAt])
}

model Booking {
  id                    String   @id @default(cuid())
  userId                String
  duffelOrderId         String?
  duffelBookingRef      String?
  status                String   @default("pending")
  totalAmount           String
  totalCurrency         String
  offerSnapshot         String
  searchParams          String
  passengerNames        String
  stripePaymentIntentId String?
  specialRequests       String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  user                  User     @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([stripePaymentIntentId])
}

// A saved search a user wants to be notified about if the price drops.
// Checked periodically by POST /api/cron/check-price-drops (see that route
// for how a real deployment would schedule the calls).
model TrackedSearch {
  id                String   @id @default(cuid())
  userId            String
  origin            String
  destination       String
  departureDate     String
  returnDate        String?
  // JSON-encoded SearchParams["passengers"], e.g. [{"type":"adult","count":1}]
  passengers        String
  cabinClass        String?
  lastKnownPrice    String
  lastKnownCurrency String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([departureDate])
}
