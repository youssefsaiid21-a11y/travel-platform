generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String           @id @default(cuid())
  email            String           @unique
  name             String?
  passwordHash     String
  createdAt        DateTime         @default(now())
  bookings         Booking[]
  passengerProfile PassengerProfile?
  trackedSearches  TrackedSearch[]
}

model PassengerProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  givenName       String
  familyName      String
  bornOn          String
  gender          String
  title           String
  phone           String
  specialRequests String?
  // Nullable: required to actually book a flight (Duffel/the airline
  // rejects international orders without them), but profiles saved before
  // this field existed won't have it yet - the booking flow treats a
  // profile missing any of these as incomplete and falls back to the form
  // instead of quick-book.
  nationality     String?
  passportNumber  String?
  passportExpiry  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id])
}

model ChatSession {
  id          String   @id
  sessionData String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([updatedAt])
}

model Booking {
  id                    String   @id @default(cuid())
  userId                String
  duffelOrderId         String?
  duffelBookingRef      String?
  status                String   @default("pending")
  totalAmount           String
  totalCurrency         String
  offerSnapshot         String
  searchParams          String
  passengerNames        String
  stripePaymentIntentId String?
  specialRequests       String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  user                  User     @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  // Unique, not just indexed: the idempotency check in POST /api/booking is
  // check-then-act (findFirst, then create) and not itself atomic, so this
  // is what actually stops two concurrent requests for the same successful
  // payment from both slipping past that check and creating two Duffel
  // orders from a single charge.
  @@unique([stripePaymentIntentId])
}

// A saved search a user wants to be notified about if the price drops.
// Checked periodically by POST /api/cron/check-price-drops (see that route
// for how a real deployment would schedule the calls).
model TrackedSearch {
  id                String   @id @default(cuid())
  userId            String
  origin            String
  destination       String
  departureDate     String
  returnDate        String?
  // JSON-encoded SearchParams["passengers"], e.g. [{"type":"adult","count":1}]
  passengers        String
  cabinClass        String?
  // Preference filters from the original search - carried over so the price
  // re-check compares against the same filtered results the user actually
  // saw (a "refundable nonstop" search must stay refundable/nonstop when
  // re-priced, not silently drop those constraints and alert on an unrelated
  // cheaper fare the user never asked for).
  preferRefundable  Boolean  @default(false)
  preferChangeable  Boolean  @default(false)
  departAfter       String?
  departBefore      String?
  maxConnections    Int?
  lastKnownPrice    String
  lastKnownCurrency String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([departureDate])
}
